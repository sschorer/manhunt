# Server
NODE_ENV=production
PORT=3000

# PostgreSQL
POSTGRES_USER=manhunt
POSTGRES_PASSWORD=change-me
POSTGRES_DB=manhunt
DATABASE_URL=postgres://manhunt:change-me@db:5432/manhunt

# Redis
REDIS_URL=redis://redis:6379

# Sessions / auth
SESSION_SECRET=change-me

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Public hostname (used by Caddy for TLS)
DOMAIN=manhunt.example.com

# Game defaults
PING_INTERVAL_S=180
POSITION_CADENCE_S=8
