# <type>(<scope>): <subject>        # <=50 chars, imperative, no trailing period
#
# <body>                            # what & why, wrap at ~72 chars
#
# <footer>                          # BREAKING CHANGE: ...   /   Closes #NN
#
# type:  feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert
# scope: client | server | infra | ci | docs | deps | release | db | vouch   (optional)
# Breaking change: add "!" after type/scope  ->  feat(server)!: ...
