{
  "name": "manhunt",
  "version": "0.1.0",
  "private": true,
  "description": "Web-based GPS manhunt game",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "client"
  ],
  "scripts": {
    "start": "node server/index.ts",
    "dev": "node --watch server/index.ts",
    "db:migrate": "node server/db/migrate.ts",
    "typecheck": "tsc --noEmit && tsc -p client --noEmit",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "test": "npm run test:server && npm run test:client",
    "test:server": "vitest run --dir server",
    "test:client": "npm run test --workspace client",
    "test:e2e": "npm run test:e2e --workspace client",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:md",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"client/**/*.css\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:fix": "eslint . --fix && stylelint \"client/**/*.css\" --fix && markdownlint-cli2 --fix \"**/*.md\"",
    "prepare": "husky || true",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.39.5",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.6",
    "jiti": "^2.7.0",
    "markdownlint-cli2": "^0.23.1",
    "socket.io-client": "^4.8.3",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
